{
  "name": "vibe-lang-highlighter",
  "displayName": "VIBE Language Support",
  "description": "Syntax highlighting and editor config for .vibe.md files (VIBE v2).",
  "version": "0.1.0",
  "publisher": "vibe",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "vibe-md",
        "aliases": ["VIBE", "vibe"],
        "extensions": [".vibe.md"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vibe-md",
        "scopeName": "text.html.markdown.vibe",
        "path": "./syntaxes/vibe-md.tmLanguage.json"
      }
    ]
  }
}
