vibe: 2.0

meta:
  name: "[project_name]"
  description: "[What this project does]"
  author: "[claude | human | agent-id]"
  tags:
    - "[tag1]"
  status: draft

imports:
  - vibe/stdlib/quality.vibe

context:
  problem: |
    [Describe what you want the project to do]

  constraints: |
    [List key constraints and limitations]

  assumptions: |
    [List assumptions about the environment and requirements]

  scope: |
    [Define what is and is not covered]

artifacts:
  - path: README.md
    kind: markdown
    description: Project README
    status: planned
    acceptance_criteria:
      - Describes the project purpose
      - Includes setup instructions

sections:
  - id: overview
    type: analysis
    title: Project Overview
    content: |
      [Describe the project at a high level. What problem does it solve?
      Who are the users?]

  - id: approach
    type: design
    title: Approach
    content: |
      [Describe the technical approach. What will be built?
      What patterns and technologies will be used?]

  - id: tasks
    type: checklist
    title: Implementation Tasks
    content: |
      - [ ] [Task 1]
      - [ ] [Task 2]
      - [ ] [Task 3]

quality:
  - id: q_complete
    type: checklist
    description: Project deliverables are complete
    criteria: |
      All artifacts are created and meet their acceptance criteria.
