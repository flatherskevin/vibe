vibe: 2.0

meta:
  name: "[project_name]_decisions"
  description: "[Collection of architectural decisions for a project or initiative]"
  author: "[claude | human | agent-id]"
  tags:
    - adr
    - decisions
  status: draft

context:
  problem: |
    [Describe the project or initiative these decisions support]

  scope: |
    [Define what decisions are covered in this collection]

sections:
  - id: background
    type: analysis
    title: Background
    content: |
      [Provide context for the decisions in this collection.
      What project or initiative do they support? What is the
      current state that these decisions address?]

decisions:
  - id: dec_001
    title: "[First decision title]"
    status: proposed
    context: |
      [Why this decision is needed]
    options:
      - name: "[option_a]"
        description: "[Description of option A]"
      - name: "[option_b]"
        description: "[Description of option B]"
    chosen: "[chosen_option]"
    rationale: |
      [Why this option was chosen over alternatives]
    consequences:
      - "[Consequence 1]"
      - "[Consequence 2]"

  - id: dec_002
    title: "[Second decision title]"
    status: proposed
    context: |
      [Why this decision is needed]
    options:
      - name: "[option_a]"
        description: "[Description of option A]"
      - name: "[option_b]"
        description: "[Description of option B]"
    chosen: "[chosen_option]"
    rationale: |
      [Why this option was chosen over alternatives]
    consequences:
      - "[Consequence 1]"

quality:
  - id: q_decisions_documented
    type: checklist
    description: All significant decisions are recorded
    criteria: |
      Every architectural or strategic decision that affects the
      project is documented with context, options, and rationale.

  - id: q_options_fair
    type: review
    description: Alternatives are fairly represented
    criteria: |
      Each decision includes at least two options with honest
      descriptions. The rationale explains trade-offs, not just
      why the chosen option is good.
