vibe: 2.0

meta:
  name: "[subject]_risk_assessment"
  description: "[Comprehensive risk analysis for a project, system, or decision]"
  author: "[claude | human | agent-id]"
  tags:
    - risk
  status: draft

context:
  problem: |
    [Describe the context requiring risk assessment]

  constraints: |
    [List constraints on risk tolerance or mitigation options]

  assumptions: |
    [List assumptions about the operating environment]

  scope: |
    [Define what is being assessed for risk]

sections:
  - id: context_analysis
    type: analysis
    title: Risk Context
    content: |
      [Provide background on the system, project, or decision being
      assessed. What is the current state? What changes are proposed?]

  - id: identified_risks
    type: risk
    title: Identified Risks
    content: |
      [List and describe each identified risk. For each risk include:
      - Description
      - Likelihood (high/medium/low)
      - Impact (high/medium/low)
      - Category (technical/operational/security/business)]

  - id: mitigations
    type: risk
    title: Mitigation Strategies
    content: |
      [For each identified risk, describe mitigation strategies.
      Include preventive measures and contingency plans.]

  - id: monitoring
    type: checklist
    title: Monitoring Plan
    content: |
      [Define how risks will be monitored over time]
      - [ ] [Monitoring item 1]
      - [ ] [Monitoring item 2]

  - id: risk_acceptance
    type: decision
    title: Risk Acceptance
    content: |
      [Document which risks are accepted and why.
      What is the residual risk after mitigations?]

quality:
  - id: q_risks_comprehensive
    type: review
    description: Risk identification is thorough
    criteria: |
      Risks cover technical, operational, security, and business
      categories. No obvious risk categories are missing.

  - id: q_mitigations_actionable
    type: review
    description: Mitigations are concrete and actionable
    criteria: |
      Each mitigation describes specific actions, not just
      aspirations. Responsible parties or triggers are identified.
