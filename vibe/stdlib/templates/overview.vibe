vibe: 2.0

meta:
  name: "[project_name]_overview"
  description: "[High-level overview of the project or initiative]"
  author: "[claude | human | agent-id]"
  tags:
    - overview
  status: draft

context:
  problem: |
    [Describe the problem being solved or the opportunity being pursued]

  constraints: |
    [List key constraints and limitations]

  assumptions: |
    [List assumptions underlying this plan]

  scope: |
    [Define what is and is not covered by this document]

  glossary: |
    [Define key terms used in this document]

sections:
  - id: problem_space
    type: analysis
    title: Problem Space
    content: |
      [Analyze the problem in detail. What is the current state?
      What pain points exist? Who is affected?]

  - id: users_stakeholders
    type: analysis
    title: Users and Stakeholders
    content: |
      [Identify who will use or be affected by this work.
      What are their needs and expectations?]

  - id: proposed_approach
    type: design
    title: Proposed Approach
    content: |
      [Describe the high-level approach to solving the problem.
      What will be built or changed?]

  - id: key_risks
    type: risk
    title: Key Risks
    content: |
      [Identify the most significant risks to this initiative.
      What could go wrong? What are the mitigations?]

  - id: success_criteria
    type: checklist
    title: Success Criteria
    content: |
      [Define what success looks like. What must be true
      for this initiative to be considered complete?]

quality:
  - id: q_problem_clear
    type: review
    description: Problem statement is clear and specific
    criteria: |
      A reader can understand what problem is being solved
      without additional context.

  - id: q_approach_actionable
    type: review
    description: Proposed approach is concrete enough to act on
    criteria: |
      The approach section describes specific actions or deliverables,
      not just aspirations.
