vibe: 2.0

meta:
  name: "[feature_name]_implementation"
  description: "[Detailed implementation plan for a specific change]"
  author: "[claude | human | agent-id]"
  tags:
    - implementation
  status: draft

context:
  problem: |
    [Describe what needs to be implemented and why]

  constraints: |
    [List implementation constraints: timeline, backward compatibility, etc.]

  assumptions: |
    [List assumptions: available dependencies, environment, etc.]

  scope: |
    [Define what files and systems are affected]

artifacts:
  - path: "[path/to/file1]"
    kind: "[language]"
    description: "[What this file does]"
    status: planned
    acceptance_criteria:
      - "[Criterion 1]"
      - "[Criterion 2]"

  - path: "[path/to/file2]"
    kind: "[language]"
    description: "[What this file does]"
    depends_on:
      - "[path/to/file1]"
    status: planned
    acceptance_criteria:
      - "[Criterion 1]"

sections:
  - id: scope_analysis
    type: analysis
    title: Scope Analysis
    content: |
      [Analyze the scope of changes. What files are touched?
      What existing behavior is affected?]

  - id: approach
    type: design
    title: Implementation Approach
    content: |
      [Describe how the implementation will proceed.
      What patterns will be used? What is the strategy?]

  - id: artifact_spec
    type: specification
    title: Artifact Specifications
    content: |
      [Detail the specific changes for each artifact.
      Include interface changes, data format changes, etc.]

  - id: task_checklist
    type: checklist
    title: Implementation Tasks
    content: |
      [Ordered list of implementation tasks]
      - [ ] [Task 1]
      - [ ] [Task 2]
      - [ ] [Task 3]

  - id: verification
    type: checklist
    title: Verification Steps
    content: |
      [How to verify the implementation is correct]
      - [ ] [Verification step 1]
      - [ ] [Verification step 2]

quality:
  - id: q_artifacts_complete
    type: checklist
    description: All planned artifacts are implemented
    criteria: |
      Every artifact in the artifacts section has status: complete
      and meets its acceptance criteria.

  - id: q_no_regressions
    type: test
    description: No existing functionality is broken
    criteria: |
      All existing tests pass. No unintended behavior changes.
