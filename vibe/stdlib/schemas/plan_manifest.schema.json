{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vibe://schemas/plan_manifest.schema.json",
  "title": "VIBE Plan Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "budgets", "operations", "validations"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vibe_version", "program_name", "created_at", "mode"],
      "properties": {
        "vibe_version": {
          "type": "string",
          "enum": ["1.0"]
        },
        "program_name": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["plan_only", "plan_and_apply"]
        },
        "agent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string" },
            "provider": { "type": "string" }
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_steps", "max_tool_calls", "max_files_changed"],
      "properties": {
        "max_steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500
        },
        "max_tool_calls": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5000
        },
        "max_files_changed": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "diff_budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_lines_added": {
              "type": "integer",
              "minimum": 0
            },
            "max_lines_removed": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "path", "reason"],
        "properties": {
          "op": {
            "type": "string",
            "enum": ["write", "patch", "mkdir", "delete"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "content": {
            "type": "string"
          },
          "patch": {
            "type": "string"
          },
          "ownership": {
            "type": "string",
            "enum": ["generated", "managed", "protected"]
          },
          "write_policy": {
            "type": "string",
            "enum": ["patch_preferred", "full_overwrite_allowed"]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "op": { "const": "write" }
              }
            },
            "then": {
              "required": ["content"]
            }
          },
          {
            "if": {
              "properties": {
                "op": { "const": "patch" }
              }
            },
            "then": {
              "required": ["patch"]
            }
          }
        ]
      }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "config"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "config": {
            "type": "object"
          }
        }
      }
    }
  }
}