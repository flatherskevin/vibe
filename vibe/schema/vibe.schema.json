{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-lang.org/schema/v1",
  "title": "VIBE Document",
  "description": "Schema for VIBE v1 document files (.vibe.md). Validates the parsed dict representation, whether sourced from YAML frontmatter + markdown body or pure YAML.",
  "type": "object",
  "required": ["vibe"],
  "properties": {
    "vibe": {
      "type": ["string", "number"],
      "description": "VIBE version identifier (must be 1.0)"
    },

    "meta": {
      "type": "object",
      "description": "Document metadata",
      "properties": {
        "name": {
          "type": "string",
          "description": "Document identifier"
        },
        "description": {
          "type": "string",
          "description": "Human-readable purpose of the document"
        },
        "session_id": {
          "type": "string",
          "description": "Links to MCP session ({YYYY-MM-DD}-{6-char-hex})",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9a-f]{6}$"
        },
        "created_at": {
          "type": "string",
          "description": "ISO date or datetime of creation"
        },
        "updated_at": {
          "type": "string",
          "description": "ISO date or datetime of last update"
        },
        "author": {
          "type": "string",
          "description": "Author identifier (e.g. claude, human, agent id)"
        },
        "tags": {
          "type": "array",
          "description": "Freeform categorization tags",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "description": "Document lifecycle status",
          "enum": ["draft", "review", "final"]
        }
      }
    },

    "imports": {
      "type": "array",
      "description": "List of .vibe.md file paths to import and merge",
      "items": {
        "type": "string"
      }
    },

    "context": {
      "type": "object",
      "description": "Problem statement, constraints, assumptions, scope, glossary, and freeform contextual data",
      "properties": {
        "problem": {
          "type": "string",
          "description": "What problem is being solved"
        },
        "constraints": {
          "type": "string",
          "description": "Boundaries and limitations"
        },
        "assumptions": {
          "type": "string",
          "description": "Assumptions underlying the plan"
        },
        "scope": {
          "type": "string",
          "description": "What is and is not covered"
        },
        "glossary": {
          "type": "string",
          "description": "Term definitions"
        }
      },
      "additionalProperties": true
    },

    "artifacts": {
      "type": "array",
      "description": "List of artifact declarations with acceptance criteria",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "File or directory path"
          },
          "kind": {
            "type": "string",
            "description": "Artifact type (python, typescript, markdown, yaml, etc.)"
          },
          "description": {
            "type": "string",
            "description": "What this artifact is for"
          },
          "depends_on": {
            "type": "array",
            "description": "Artifact paths this depends on",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "array",
            "description": "Conditions that define when this artifact is done",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "description": "Artifact tracking status",
            "enum": ["planned", "in_progress", "complete"]
          }
        }
      }
    },

    "sections": {
      "type": "array",
      "description": "Ordered list of document sections",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique section identifier within the document"
          },
          "type": {
            "type": "string",
            "description": "Section content type",
            "enum": ["analysis", "design", "decision", "specification", "risk", "checklist"]
          },
          "title": {
            "type": "string",
            "description": "Human-readable section heading"
          },
          "content": {
            "type": "string",
            "description": "Section body content (markdown text)"
          },
          "depends_on": {
            "type": "array",
            "description": "Section IDs this section builds on",
            "items": { "type": "string" }
          }
        }
      }
    },

    "decisions": {
      "type": "array",
      "description": "Architecture Decision Records",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique decision identifier within the document"
          },
          "title": {
            "type": "string",
            "description": "One-line decision summary"
          },
          "status": {
            "type": "string",
            "description": "Decision lifecycle status",
            "enum": ["proposed", "accepted", "deprecated", "superseded"]
          },
          "context": {
            "type": "string",
            "description": "Why this decision is needed"
          },
          "options": {
            "type": "array",
            "description": "Alternatives considered",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Option identifier"
                },
                "description": {
                  "type": "string",
                  "description": "What this option entails"
                }
              }
            }
          },
          "chosen": {
            "type": "string",
            "description": "Name of the chosen option"
          },
          "rationale": {
            "type": "string",
            "description": "Why this option was chosen"
          },
          "consequences": {
            "type": "array",
            "description": "What follows from this choice",
            "items": { "type": "string" }
          }
        }
      }
    },

    "quality": {
      "type": "array",
      "description": "Quality criteria that define done",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique quality criterion identifier"
          },
          "type": {
            "type": "string",
            "description": "Quality criterion type",
            "enum": ["review", "test", "metric", "checklist"]
          },
          "description": {
            "type": "string",
            "description": "What is being checked"
          },
          "criteria": {
            "type": "string",
            "description": "How to determine pass/fail"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
