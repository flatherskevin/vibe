vibe: 1.0

imports:
  - vibe/stdlib/tools.vibe
  - vibe/stdlib/gates.vibe
  - vibe/stdlib/context_budget.vibe
  - vibe/stdlib/plan_manifest_schema.vibe
  - vibe/stdlib/validators.vibe

context:
  subagent_program_purpose: |
    Canonical multi-agent orchestration program for VIBE v1.

    This program demonstrates how a parent runtime may use bounded subagents
    during PLAN while retaining final authority over:
    - manifest generation
    - manifest validation
    - APPLY
    - final validation

    Subagents are treated as structured contributors, not autonomous executors.

  subagent_roles: |
    [
      {
        "id": "repo_researcher",
        "role": "researcher",
        "goal": "Inspect the existing repository and summarize relevant structure, constraints, and patterns.",
        "tools_allowed": ["fs.read", "fs.list"],
        "write_scope": ["spec/subagents/"],
        "handoff_artifact": "spec/subagents/repo_research.json"
      },
      {
        "id": "artifact_planner",
        "role": "planner",
        "goal": "Propose artifacts, file responsibilities, and workflow breakdown based on the research handoff.",
        "tools_allowed": ["fs.read", "fs.list", "fs.write"],
        "write_scope": ["spec/subagents/"],
        "handoff_artifact": "spec/subagents/artifact_plan.json"
      },
      {
        "id": "draft_generator",
        "role": "generator",
        "goal": "Draft implementation recommendations and patch/write proposals without applying them.",
        "tools_allowed": ["fs.read", "fs.list", "fs.write"],
        "write_scope": ["spec/subagents/"],
        "handoff_artifact": "spec/subagents/draft_outputs.json"
      },
      {
        "id": "plan_validator",
        "role": "validator",
        "goal": "Review proposed plan artifacts and identify conflicts, missing dependencies, or policy risks.",
        "tools_allowed": ["fs.read", "fs.list", "fs.write"],
        "write_scope": ["spec/subagents/"],
        "handoff_artifact": "spec/subagents/plan_review.json"
      }
    ]

artifacts:
  - path: spec/subagents/repo_research.json
    kind: json
    ownership: generated
    write_policy: full_overwrite_allowed
    source:
      generate: |
        Produce a structured repository research summary.

        Include:
        - important existing directories
        - relevant source files
        - known constraints
        - likely implementation targets
        - risks or ambiguities
    invariants:
      - Must be valid JSON
      - Must summarize the repo structure and relevant constraints

  - path: spec/subagents/artifact_plan.json
    kind: json
    ownership: generated
    write_policy: full_overwrite_allowed
    depends_on:
      - spec/subagents/repo_research.json
    source:
      generate: |
        Produce a structured artifact and workflow proposal.

        Include:
        - proposed files
        - file purposes
        - dependency ordering
        - suggested workflow breakdown
    invariants:
      - Must be valid JSON
      - Must include proposed artifacts and dependency ordering

  - path: spec/subagents/draft_outputs.json
    kind: json
    ownership: generated
    write_policy: full_overwrite_allowed
    depends_on:
      - spec/subagents/artifact_plan.json
    source:
      generate: |
        Produce draft implementation recommendations based on the proposed artifacts.

        Include:
        - draft file outputs or patch suggestions
        - rationale for each draft
        - any unresolved issues
    invariants:
      - Must be valid JSON
      - Must not claim that repository changes were applied

  - path: spec/subagents/plan_review.json
    kind: json
    ownership: generated
    write_policy: full_overwrite_allowed
    depends_on:
      - spec/subagents/repo_research.json
      - spec/subagents/artifact_plan.json
      - spec/subagents/draft_outputs.json
    source:
      generate: |
        Produce a structured review of the proposed plan.

        Include:
        - validation concerns
        - policy concerns
        - missing dependencies
        - missing validations
        - recommendation: approve or revise
    invariants:
      - Must be valid JSON
      - Must include an approval recommendation

  - path: spec/00_overview.md
    kind: markdown
    ownership: generated
    write_policy: full_overwrite_allowed
    depends_on:
      - spec/subagents/repo_research.json
    source:
      generate: |
        Write a high level overview of the project informed by the repo_research handoff.

        Include:
        - Problem
        - Intended users
        - Success Criteria

  - path: spec/10_architecture.md
    kind: markdown
    ownership: generated
    write_policy: full_overwrite_allowed
    depends_on:
      - spec/subagents/repo_research.json
      - spec/subagents/artifact_plan.json
    source:
      generate: |
        Write an architecture document informed by the subagent handoffs.

        Include:
        - Components
        - Responsibilities
        - Interfaces
        - Constraints

  - path: spec/20_artifacts.json
    kind: json
    ownership: generated
    write_policy: full_overwrite_allowed
    depends_on:
      - spec/subagents/artifact_plan.json
      - spec/10_architecture.md
    source:
      generate: |
        Produce the authoritative artifact manifest using the approved subagent planning outputs.

  - path: spec/30_workflow.json
    kind: json
    ownership: generated
    write_policy: full_overwrite_allowed
    depends_on:
      - spec/subagents/artifact_plan.json
      - spec/subagents/plan_review.json
      - spec/20_artifacts.json
    source:
      generate: |
        Produce the authoritative workflow summary using the approved subagent planning outputs.

  - path: spec/runlog_compacted.md
    kind: markdown
    ownership: generated
    write_policy: full_overwrite_allowed
    source:
      generate: |
        Runtime-maintained compact execution log.

        Include:
        - steps executed
        - subagents invoked
        - files changed
        - gates and validators
        - remaining tasks

workflow:
  mode: plan_and_apply

  steps:
    - id: run_repo_researcher
      type: plan
      goal: Invoke the researcher subagent to inspect the repository and produce a structured handoff.
      inputs:
        - context
        - project.vibe
      outputs: |
        {
          "type": "object",
          "properties": {
            "handoff_path": {
              "type": "string",
              "const": "spec/subagents/repo_research.json"
            }
          },
          "required": ["handoff_path"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_exists",
            "config": {
              "path": "spec/subagents/repo_research.json"
            }
          }
        ]
      retry:
        max: 2
        on_fail: revise
      tools_allowed:
        - fs.read
        - fs.list
        - fs.write

    - id: run_artifact_planner
      type: plan
      goal: Invoke the planner subagent to propose artifacts and dependency ordering.
      inputs:
        - spec/subagents/repo_research.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "handoff_path": {
              "type": "string",
              "const": "spec/subagents/artifact_plan.json"
            }
          },
          "required": ["handoff_path"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_exists",
            "config": {
              "path": "spec/subagents/artifact_plan.json"
            }
          }
        ]
      retry:
        max: 2
        on_fail: revise
      tools_allowed:
        - fs.read
        - fs.list
        - fs.write

    - id: run_draft_generator
      type: generate
      goal: Invoke the generator subagent to draft implementation recommendations without mutating the repo.
      inputs:
        - spec/subagents/repo_research.json
        - spec/subagents/artifact_plan.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "handoff_path": {
              "type": "string",
              "const": "spec/subagents/draft_outputs.json"
            }
          },
          "required": ["handoff_path"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_exists",
            "config": {
              "path": "spec/subagents/draft_outputs.json"
            }
          }
        ]
      retry:
        max: 2
        on_fail: revise
      tools_allowed:
        - fs.read
        - fs.list
        - fs.write

    - id: run_plan_validator
      type: validate
      goal: Invoke the validator subagent to review the proposed plan and issue an approval recommendation.
      inputs:
        - spec/subagents/repo_research.json
        - spec/subagents/artifact_plan.json
        - spec/subagents/draft_outputs.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "handoff_path": {
              "type": "string",
              "const": "spec/subagents/plan_review.json"
            }
          },
          "required": ["handoff_path"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_exists",
            "config": {
              "path": "spec/subagents/plan_review.json"
            }
          }
        ]
      retry:
        max: 2
        on_fail: revise
      tools_allowed:
        - fs.read
        - fs.list
        - fs.write

    - id: generate_parent_planning_docs
      type: plan
      goal: Parent runtime normalizes approved subagent handoffs into canonical planning docs.
      inputs:
        - spec/subagents/repo_research.json
        - spec/subagents/artifact_plan.json
        - spec/subagents/draft_outputs.json
        - spec/subagents/plan_review.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "files_created": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["files_created"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_tree",
            "config": {
              "required": [
                "spec/00_overview.md",
                "spec/10_architecture.md",
                "spec/20_artifacts.json",
                "spec/30_workflow.json"
              ]
            }
          }
        ]
      retry:
        max: 2
        on_fail: revise
      tools_allowed:
        - fs.read
        - fs.write

    - id: plan_manifest
      type: plan
      goal: Parent runtime produces the final authoritative plan manifest using approved planning outputs.
      inputs:
        - spec/00_overview.md
        - spec/10_architecture.md
        - spec/20_artifacts.json
        - spec/30_workflow.json
        - spec/subagents/plan_review.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "plan_manifest_path": {
              "type": "string",
              "const": "spec/plan_manifest.json"
            }
          },
          "required": ["plan_manifest_path"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_exists",
            "config": {
              "path": "spec/plan_manifest.json"
            }
          },
          {
            "type": "json_schema",
            "config": {
              "instance_path": "spec/plan_manifest.json",
              "schema_path": "vibe/stdlib/schemas/plan_manifest.schema.json"
            }
          }
        ]
      retry:
        max: 2
        on_fail: revise
      tools_allowed:
        - fs.read
        - fs.write

    - id: apply_operations
      type: apply
      goal: Parent runtime applies only the operations listed in the final plan manifest.
      inputs:
        - spec/plan_manifest.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "applied": { "type": "boolean" },
            "files_touched": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["applied", "files_touched"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_tree",
            "config": {
              "required": ["spec/plan_manifest.json"]
            }
          },
          {
            "type": "diff_budget",
            "config": {
              "max_lines_added": 2000,
              "max_lines_removed": 2000
            }
          }
        ]
      retry:
        max: 1
        on_fail: abort
      tools_allowed:
        - fs.read
        - fs.list
        - fs.write
        - fs.apply_patch

    - id: validate_from_manifest
      type: validate
      goal: Parent runtime runs final validations from the authoritative plan manifest.
      inputs:
        - spec/plan_manifest.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "validations_passed": { "type": "boolean" },
            "validators_run": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["validations_passed", "validators_run"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "json_schema",
            "config": {
              "instance_path": "spec/plan_manifest.json",
              "schema_path": "vibe/stdlib/schemas/plan_manifest.schema.json"
            }
          }
        ]
      retry:
        max: 1
        on_fail: abort
      tools_allowed:
        - fs.read
        - exec.run

    - id: summarize_run
      type: summarize
      goal: Parent runtime writes a compact run summary including subagent activity and final execution results.
      inputs:
        - spec/subagents/repo_research.json
        - spec/subagents/artifact_plan.json
        - spec/subagents/draft_outputs.json
        - spec/subagents/plan_review.json
        - spec/plan_manifest.json
      outputs: |
        {
          "type": "object",
          "properties": {
            "summary_written": { "type": "boolean" }
          },
          "required": ["summary_written"],
          "additionalProperties": false
        }
      gate: |
        [
          {
            "type": "file_exists",
            "config": {
              "path": "spec/runlog_compacted.md"
            }
          }
        ]
      retry:
        max: 1
        on_fail: revise
      tools_allowed:
        - fs.write